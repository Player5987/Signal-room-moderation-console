# ---- Database (Postgres; e.g. Neon/Supabase) ----
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ---- Auth (Google sign-in via Auth.js / NextAuth) ----
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 33)
AUTH_SECRET="paste-a-long-random-string"
# From Google Cloud Console -> Credentials -> OAuth client (Web application):
AUTH_GOOGLE_ID="xxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxx"
# Comma-separated emails that should be admins (everyone else is a normal user):
ADMIN_EMAILS="you@gmail.com"

# ---- LLM provider (multilingual classification) ----
# Groq (free, OpenAI-compatible):
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="llama-3.3-70b-versatile"
# Without a key the app uses the English-only mock classifier.

# ---- Image moderation (optional) ----
# IMAGE_SERVICE_URL="http://localhost:8000"
