# ---- Database ----
# Local dev uses SQLite (no setup). For deployment, switch the provider in
# prisma/schema.prisma to "postgresql" and put a Postgres URL here (Neon/Supabase).
DATABASE_URL="file:./dev.db"

# ---- Admin access ----
# Password for the admin areas (Dashboard, Evaluation, Policies). Default is "admin".
ADMIN_PASSWORD="admin"

# ---- LLM provider ----
# Without a key, the app runs on the built-in mock classifiers.
#
# Groq (free, no card, OpenAI-compatible):
# OPENAI_API_KEY="gsk_..."
# OPENAI_BASE_URL="https://api.groq.com/openai/v1"
# OPENAI_MODEL="llama-3.3-70b-versatile"
#
# Gemini (free tier; OpenAI-compatible):
# OPENAI_API_KEY="your-gemini-key"
# OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# OPENAI_MODEL="gemini-2.5-flash"
#
# OpenAI (paid): set only the key; leave BASE_URL/MODEL unset for gpt-4o-mini.
# OPENAI_API_KEY="sk-..."

# ---- Image moderation (optional) ----
# Start the Python service, then set this to enable image scoring.
# IMAGE_SERVICE_URL="http://localhost:8000"
