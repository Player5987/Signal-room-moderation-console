// Prisma schema. Dev uses SQLite; for production switch provider to "postgresql".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) models ----------
// Standard tables the Prisma adapter expects, plus a `role` on User.

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          String         @default("user") // "user" | "admin"
  createdAt     DateTime       @default(now())
  accounts      Account[]
  sessions      Session[]
  contentItems  ContentItem[]
  reviews       ReviewAction[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Moderation domain ----------

model Policy {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String
  active      Boolean  @default(true)
  builtin     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// A single piece of content submitted for moderation — now owned by a user.
model ContentItem {
  id        String            @id @default(cuid())
  text      String
  imageUrl  String?
  source    String            @default("web")
  status    String            @default("pending")
  createdAt DateTime          @default(now())
  // Owner. Nullable so seeded/system content can exist without a user.
  userId    String?
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  result    ModerationResult?
  reviews   ReviewAction[]
}

model ModerationResult {
  id            String      @id @default(cuid())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentItemId String      @unique
  category      String
  confidence    Float
  scores        String
  rationale     String
  language      String? // detected language of the content (Stage 5: multilingual)
  engine        String      @default("mock")
  createdAt     DateTime    @default(now())
}

model ReviewAction {
  id            String      @id @default(cuid())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  contentItemId String
  reviewer      User        @relation(fields: [reviewerId], references: [id])
  reviewerId    String
  decision      String
  note          String?
  createdAt     DateTime    @default(now())
}
